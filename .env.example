# Azure Services (used by the API service, not the SPA)
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Reasoning model deployment for the Spotify agent (optional — uses responses API with visible reasoning)
# Deploy a GPT-5 or o-series reasoning model and set the deployment name here.
# When set, the Spotify agent will use client.responses.create() with reasoning: { effort: "medium", summary: "auto" }.
# If not set, the agent falls back to the standard gpt-4o chat completions path.
AZURE_OPENAI_REASONING_DEPLOYMENT=gpt-5.4

# Model Router deployment (optional — enables the Model Router demo)
# Deploy a model-router in Azure AI Foundry and set the deployment name here.
# The model router intelligently routes prompts to the best-suited model based on routing mode.
AZURE_OPENAI_MODEL_ROUTER_DEPLOYMENT=model-router

# gpt-image-2 deployment (optional — enables the AI Creative Studio image generation demo)
# Deploy gpt-image-2 in Azure AI Foundry and set the deployment name here.
# Without this the demo runs in mock mode (placeholder images, no Azure calls).
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2

# MAI-Image-2e deployment via Azure AI Foundry (optional — enables MAI model in AI Creative Studio)
# Deploy MAI-Image-2e in Azure AI Foundry and set the endpoint and deployment name here.
# The managed identity must have Cognitive Services User role on the AI Foundry resource.
AZURE_AI_FOUNDRY_ENDPOINT=https://<your-ai-foundry-resource>.services.ai.azure.com
AZURE_AI_FOUNDRY_IMAGE_DEPLOYMENT=MAI-Image-2e

# Azure AI Search (optional — enables RAG for knowledge base documents)
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_INDEX=knowledge-base

# Spotify (used by the SPA for PKCE auth — get a Client ID from https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=<your-spotify-client-id>

# Tavily Search API (used by the Spotify agent to research music requests — get a free key from https://app.tavily.com)
# Without this key the web_search tool will return a graceful error and the agent will fall back to Spotify-only search.
TAVILY_API_KEY=<your-tavily-api-key>
